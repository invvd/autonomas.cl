---
// Basic Dark Testimonial section
// ------------
// Description: A centered testimonial section that contains: a quote, a caption and a cite in a dark section with a background image.

// Components
// - Layout
import Section from '../../ui/Section.astro'
import Row from '../../ui/Row.astro'
import Col from '../../ui/Col.astro'
// - UI
import Testimonial from '../../ui/Testimonial.astro'

// Props
type Props = {
	blockquote?: string
	figcaption?: string
	cite?: string
	bg?: any
	bgPosition?: 'left' | 'right' | 'center'
}
const {
	blockquote = 'Ya tengo mi licencia de conducir y ahora, después de 2 años, por fin manejo mi auto. Agradezco mucho por la confianza que entregan y sobretodo a mi coach Macarena que me dio toda la confianza, se portó excelente. Recomiendo 100% aprender con ustedes.',
	figcaption = 'Verónica Jiménez',
	cite = 'Alumna de Autónomas.',
	bg,
	bgPosition = 'center'
} = Astro.props
---

<Section
	id="testimonial"
	mode="light"
	bg={bg}
	bgPosition={bgPosition}
	classes="z-10 border-y border-neutral-800"
>
	<Row>
		<Col span="12">
			<Testimonial
				blockquote={blockquote}
				figcaption={figcaption}
				cite={cite}
				align="center"
				size="4xl"
				mobileSize="2xl"
				classes="!leading-tight font-bold xl:text-5xl max-w-7xl mx-auto"
				quoteSize={112}
			/>
		</Col>
	</Row>
</Section>
